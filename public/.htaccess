# Reset rewrite handling for this directory so nothing is inherited from a
# parent .htaccess (e.g. WordPress's own rewrite rules, if this build is
# deployed into a subfolder of a WordPress docroot).
RewriteEngine On
RewriteBase /

# Single-page-app fallback: serve index.html for any path that isn't a real
# file or directory, so React Router can handle client-side routes like
# /residential or /quote directly (not just via in-app navigation).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
